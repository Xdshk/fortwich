<Window x:Class="TwitchStressToolkit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Twitch Stress Toolkit"
        Height="920"
        Width="1480"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        MinHeight="760"
        MinWidth="1200">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" DataContext="{Binding}">
            <MenuItem Header="File">
                <MenuItem Header="Load Accounts..." Command="{Binding LoadAccountsCommand}" Foreground="White"/>
                <Separator/>
                <MenuItem Header="Export Diagnostics..." Command="{Binding ExportDiagnosticsCommand}" Foreground="White"/>
                <Separator/>
                <MenuItem Header="Exit" Command="{Binding ExitCommand}" Foreground="White"/>
            </MenuItem>
            <MenuItem Header="Simulation">
                <MenuItem Header="Start" Command="{Binding StartSimulationCommand}" Foreground="White"/>
                <MenuItem Header="Stop" Command="{Binding StopSimulationCommand}" Foreground="White"/>
            </MenuItem>
            <MenuItem Header="Tools">
                <MenuItem Header="Dashboard" Command="{Binding ShowDashboardCommand}" Foreground="White"/>
                <MenuItem Header="Bot Manager" Command="{Binding ShowBotManagerCommand}" Foreground="White"/>
                <MenuItem Header="Charts" Command="{Binding ShowChartsCommand}" Foreground="White"/>
                <Separator/>
                <MenuItem Header="Settings" Command="{Binding ShowSettingsCommand}" Foreground="White"/>
                <MenuItem Header="Logs" Command="{Binding ShowLogsCommand}" Foreground="White"/>
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="About" Command="{Binding AboutCommand}" Foreground="White"/>
            </MenuItem>
        </Menu>

        <Border Grid.Row="1" Margin="18,14,18,0" Padding="22" CornerRadius="24" BorderThickness="1">
            <Border.BorderBrush>
                <SolidColorBrush Color="#223043"/>
            </Border.BorderBrush>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#18212B" Offset="0"/>
                    <GradientStop Color="#10161D" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="1.3*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Control Center"
                               FontSize="13"
                               Foreground="{DynamicResource AccentBrush}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Local diagnostics and UI overview"
                               Margin="0,10,0,0"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Margin="0,12,0,0"
                               FontSize="15"
                               Foreground="{DynamicResource SubtextBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding ConfiguredChannelDisplay}"
                               Margin="0,8,0,0"
                               FontSize="14"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="{Binding MaxClients, StringFormat=Shared client limit: {0}}"
                               Margin="0,6,0,0"
                               FontSize="13"
                               Foreground="{DynamicResource SubtextBrush}"/>
                </StackPanel>

                <UniformGrid Grid.Column="1" Columns="2" Margin="18,0,0,0">
                    <Border Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Active connections" Style="{StaticResource SummaryLabelStyle}"/>
                            <TextBlock Text="{Binding ActiveConnections}" Style="{StaticResource SummaryValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Messages tracked" Style="{StaticResource SummaryLabelStyle}"/>
                            <TextBlock Text="{Binding MessagesPerSecond}" Style="{StaticResource SummaryValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Latency" Style="{StaticResource SummaryLabelStyle}"/>
                            <TextBlock Text="{Binding Latency, StringFormat={}{0:F0} ms}" Style="{StaticResource SummaryValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Errors" Style="{StaticResource SummaryLabelStyle}"/>
                            <TextBlock Text="{Binding ErrorCount}" Style="{StaticResource SummaryValueStyle}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="18,16,18,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Dashboard" Command="{Binding ShowDashboardCommand}" Style="{StaticResource NavButtonStyle}"/>
                <Button Content="Bot Manager" Command="{Binding ShowBotManagerCommand}" Style="{StaticResource NavButtonStyle}"/>
                <Button Content="Charts" Command="{Binding ShowChartsCommand}" Style="{StaticResource NavButtonStyle}"/>
                <Button Content="Settings" Command="{Binding ShowSettingsCommand}" Style="{StaticResource NavButtonStyle}"/>
                <Button Content="Logs" Command="{Binding ShowLogsCommand}" Style="{StaticResource NavButtonStyle}"/>
            </StackPanel>

            <TabControl x:Name="MainTabControl" Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <TabItem Header="Dashboard">
                <ContentControl x:Name="DashboardContent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
            </TabItem>

            <TabItem Header="Bot Manager">
                <ContentControl x:Name="BotManagerContent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
            </TabItem>

            <TabItem Header="Charts">
                <ContentControl x:Name="ChartsContent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
            </TabItem>

            <TabItem Header="Settings">
                <ContentControl x:Name="SettingsContent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
            </TabItem>

            <TabItem Header="Logs">
                <TextBox x:Name="LogTextBox"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         Background="#0D1117"
                         Foreground="#D7E0EA"
                         FontFamily="Consolas"
                         FontSize="12"
                         BorderThickness="0"
                         Padding="16"
                         Text="{Binding LogsText}"/>
            </TabItem>
            </TabControl>
        </Grid>

        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ActiveConnections, StringFormat=Connections: {0}}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding MessagesPerSecond, StringFormat=Messages: {0}}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ErrorCount, StringFormat=Errors: {0}}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>

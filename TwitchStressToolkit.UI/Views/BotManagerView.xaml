<UserControl x:Class="TwitchStressToolkit.UI.Views.BotManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16" Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="18" CornerRadius="18" Background="{DynamicResource SurfaceBrush}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Bot Manager"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="Local account list, channel mapping and import status."
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource SubtextBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <TextBlock Text="Shared channel"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   Margin="0,0,10,0"/>
                        <TextBox Text="{Binding TargetChannel, UpdateSourceTrigger=PropertyChanged}"
                                 Width="220"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <Border Grid.Column="1" Style="{StaticResource SummaryCardStyle}" MinWidth="140">
                    <StackPanel>
                        <TextBlock Text="Accounts loaded" Style="{StaticResource SummaryLabelStyle}"/>
                        <TextBlock Text="{Binding Accounts.Count}" Style="{StaticResource SummaryValueStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="18" Padding="18" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Accounts file"
                               Foreground="{DynamicResource SubtextBrush}"
                               Margin="0,0,0,8"/>
                    <TextBox Text="{Binding AccountsFile, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Load File"
                        Command="{Binding LoadAccountsCommand}"
                        Margin="12,24,0,0"
                        MinWidth="120"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="18" Padding="18" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Username" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="Password" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Text="Auth token" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding NewAuthToken, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,12,0">
                    <TextBlock Text="Channel" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding NewChannel, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="4"
                        Content="Add"
                        Command="{Binding AddAccountCommand}"
                        Margin="0,24,0,0"
                        MinWidth="96"/>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="3" Margin="0,0,0,16">
            <Button Content="Remove" Command="{Binding RemoveAccountCommand}" MinWidth="120"/>
            <Button Content="Change Channel" Command="{Binding ChangeChannelCommand}" MinWidth="150"/>
            <Button Content="Validate" Command="{Binding ValidateAccountCommand}" MinWidth="120"/>
            <Button Content="Validate All" Command="{Binding ValidateAllCommand}" MinWidth="140"/>
        </WrapPanel>

        <Border Grid.Row="4" Background="{DynamicResource SurfaceBrush}" CornerRadius="18" Padding="12">
            <Grid>
                <DataGrid ItemsSource="{Binding Accounts}"
                          SelectedItem="{Binding SelectedAccount}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Width="130" Binding="{Binding Id}"/>
                        <DataGridTextColumn Header="Username" Width="180" Binding="{Binding Username}"/>
                        <DataGridTextColumn Header="Channel" Width="180" Binding="{Binding CurrentChannel}"/>
                        <DataGridTextColumn Header="Status" Width="120" Binding="{Binding Status}"/>
                        <DataGridTextColumn Header="Bans" Width="80" Binding="{Binding BanCount}"/>
                        <DataGridTextColumn Header="Last Used" Width="180" Binding="{Binding LastUsedAt, StringFormat={}{0:g}}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Text="No accounts loaded yet."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtextBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Accounts.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <StatusBar Grid.Row="5">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding Accounts.Count, StringFormat='Total: {0}'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding TargetChannel, StringFormat='Channel: #{0}'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>

<UserControl x:Class="TwitchStressToolkit.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <Grid Margin="16" Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Dashboard"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="0,0,0,16"/>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
            <Border Background="#2D2D2D" Padding="16" CornerRadius="8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Active" Foreground="#AAAAAA" FontSize="12"/>
                    <TextBlock Text="{Binding ActiveConnections}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#2D2D2D" Padding="16" CornerRadius="8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Msg/sec" Foreground="#AAAAAA" FontSize="12"/>
                    <TextBlock Text="{Binding MessagesPerSecond}" Foreground="#00FF88" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#2D2D2D" Padding="16" CornerRadius="8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Latency" Foreground="#AAAAAA" FontSize="12"/>
                    <TextBlock Text="{Binding Latency, StringFormat={}{0:F0} ms}" Foreground="#FF8800" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#2D2D2D" Padding="16" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Errors" Foreground="#AAAAAA" FontSize="12"/>
                    <TextBlock Text="{Binding ErrorCount}" Foreground="#FF4444" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#2D2D2D" Padding="8" CornerRadius="8" Margin="0,0,0,8">
                <lvc:CartesianChart Series="{Binding LatencyChartSeries}"
                                    XAxes="{Binding XAxes}"
                                    YAxes="{Binding YAxes}"
                                    TooltipPosition="Top"
                                    AnimationsSpeed="00:00:00.150"/>
            </Border>

            <Border Grid.Row="1" Background="#2D2D2D" Padding="8" CornerRadius="8">
                <lvc:CartesianChart Series="{Binding ThroughputChartSeries}"
                                    XAxes="{Binding XAxes}"
                                    YAxes="{Binding YAxes}"
                                    AnimationsSpeed="00:00:00.150"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>

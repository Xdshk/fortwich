<UserControl x:Class="TwitchStressToolkit.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16" Background="{DynamicResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="18" Padding="18" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Settings"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="Shared configuration for the desktop UI."
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource SubtextBrush}"/>
                        <TextBlock Text="{Binding TargetChannelDisplay}"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="{Binding SettingsPathText}"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtextBrush}"/>
                    </StackPanel>

                    <WrapPanel Grid.Column="1" VerticalAlignment="Top" Margin="16,0,0,0">
                        <Button Content="Save" Command="{Binding SaveSettingsCommand}" MinWidth="110"/>
                        <Button Content="Reset Defaults" Command="{Binding ResetDefaultsCommand}" MinWidth="150"/>
                        <Button Content="Open Data" Command="{Binding OpenDataFolderCommand}" MinWidth="120"/>
                        <Button Content="Open Exports" Command="{Binding OpenExportsFolderCommand}" MinWidth="130"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16" Padding="14" Margin="0,0,0,16">
                <TextBlock Text="{Binding StatusText}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextBrush}"/>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="18" Padding="18" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Connection Settings"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"
                                   Margin="0,0,0,16"/>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Max Clients" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding MaxClients}" Width="140"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Connection Timeout (ms)" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding ConnectionTimeoutMs}" Width="160"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Reconnect Delay (ms)" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding ReconnectDelayMs}" Width="160"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Max Reconnects" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding MaxReconnectAttempts}" Width="160"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Heartbeat (ms)" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding HeartbeatIntervalMs}" Width="160"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Ramp-up Delay (ms)" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding RampUpDelayMs}" Width="160"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Target Channel" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding TargetChannel, UpdateSourceTrigger=PropertyChanged}" Width="260"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="18" Padding="18" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Activity Settings"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"
                                   Margin="0,0,0,16"/>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Min Message Delay (ms)" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding MessageSendMinDelayMs}" Width="160"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Max Message Delay (ms)" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding MessageSendMaxDelayMs}" Width="160"/>
                        </StackPanel>

                        <CheckBox Content="Enable Chat Simulation"
                                  IsChecked="{Binding EnableChat}"/>

                        <CheckBox Content="Enable Viewer Emulation"
                                  IsChecked="{Binding EnableViewer}"/>

                        <CheckBox Content="Enable Auto-Reconnect"
                                  IsChecked="{Binding EnableReconnects}"/>

                        <CheckBox Content="Enable Proxy Rotation"
                                  IsChecked="{Binding EnableAutoRotate}"/>

                        <TextBlock Text="Server Endpoints"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"
                                   Margin="0,20,0,16"/>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="IRC URL" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding IrcUrl}" MinWidth="320"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="GQL URL" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding GqlUrl}" MinWidth="320"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
